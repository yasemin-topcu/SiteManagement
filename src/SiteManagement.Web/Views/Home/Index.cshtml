@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container py-4">
    <div class="row align-items-center g-4">
        <div class="col-md-6">
            <h1 class="display-6 fw-bold">Apartman Yönetim Uygulamasına Hoşgeldiniz</h1>
            <p class="lead text-muted">
                Aidat, duyuru, arıza bildirimleri ve daire yönetimi süreçlerini tek yerden yönetin.
            </p>

            <div class="d-flex gap-2">
                <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">Kaydol</a>
            </div>
        </div>

        <div class="col-md-6">
            <img src="~/images/hero.jpg" class="img-fluid rounded shadow" alt="Apartman yönetimi" />
        </div>
    </div>
</div>